---
import Layout from "../layouts/Layout.astro";
import CardProgramme from "../components/cards/CardProgramme.astro";
import {
    getFilteredArtists,
    getToutesLesScenes,
    getArtistsByDate,
} from "../../backend/backend.mjs";
import DownloadIcon from "../assets/icons/Telechargement.svg";
import FiltreIcon from "../assets/icons/Filtre.svg";

const genre = Astro.url.searchParams.get("genre") || "";
const scene = Astro.url.searchParams.get("scene") || "";
const ordre = Astro.url.searchParams.get("ordre") || "asc";


const allArtistes = await getArtistsByDate();
const artistes = await getFilteredArtists(genre, scene, ordre);
const toutesLesScenes = await getToutesLesScenes();

console.log(artistes);

const listeGenres = [...new Set(allArtistes.map((a) => a.genre_musicale))];
---

<Layout title="Programme - Flying Tap Fest" description="Découvrez le programme complet du Flying Tap Fest : les artistes, les horaires et les scènes pour une expérience inoubliable de tap dance." >
    <main class="bg-beige min-h-screen pb-24">
        <section class="pt-20 lg:pt-32 pb-12 px-6">
            <div class="max-w-7xl mx-auto">
                <h1
                    class="font-abril text-moutarde text-7xl lg:text-9xl leading-none text-left"
                >
                    Programme
                </h1>
            </div>
        </section>
        <section class="px-6 mb-20">
            <div class="max-w-7xl mx-auto flex flex-col items-center gap-10">
                <div
                    class="bg-[#1A1A1A] rounded-[40px] p-8 lg:p-12 w-full max-w-5xl shadow-2xl"
                >
                    <div class="flex items-center gap-3 mb-10 text-moutarde">
                        <img src={FiltreIcon.src} alt="" class="w-6 h-6" />
                        <span class="font-playfair text-2xl">Filtres</span>
                    </div>

                    <form
                        method="GET"
                        class="grid grid-cols-1 lg:grid-cols-3 gap-8"
                    >
                        <div class="flex flex-col gap-2">
                            <label
                                class="font-playfair text-beige/50 text-lg ml-4"
                                >Genre</label
                            >
                            <select
                                name="genre"
                                onchange="this.form.submit()"
                                class="bg-beige text-moutarde font-playfair text-xl py-4 px-6 rounded-full appearance-none outline-none cursor-pointer w-full"
                            >
                                <option value="">Tous les genres</option>
                                {
                                    listeGenres.map((g) => (
                                        <option
                                            value={g}
                                            selected={genre === g}
                                        >
                                            {g}
                                        </option>
                                    ))
                                }
                            </select>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label
                                class="font-playfair text-beige/50 text-lg ml-4"
                                >Horaire</label
                            >
                            <select
                                name="ordre"
                                onchange="this.form.submit()"
                                class="bg-beige text-moutarde font-playfair text-xl py-4 px-6 rounded-full appearance-none outline-none cursor-pointer w-full"
                            >
                                <option value="asc" selected={ordre === "asc"}
                                    >Le plus tôt</option
                                >
                                <option value="desc" selected={ordre === "desc"}
                                    >Le plus tard</option
                                >
                            </select>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label
                                class="font-playfair text-beige/50 text-lg ml-4"
                                >Scène</label
                            >
                            <select
                                name="scene"
                                onchange="this.form.submit()"
                                class="bg-beige text-moutarde font-playfair text-xl py-4 px-6 rounded-full appearance-none outline-none cursor-pointer w-full"
                            >
                                <option value="">Toutes les scènes</option>
                                {
                                    toutesLesScenes.map((s) => (
                                        <option
                                            value={s.nom_scene}
                                            selected={scene === s.nom_scene}
                                        >
                                            {s.nom_scene}
                                        </option>
                                    ))
                                }
                            </select>
                        </div>
                    </form>
                </div>

                <a
                    href="/programme.pdf"
                    class="bg-rouge text-beige font-abril text-xl py-5 px-10 rounded-full w-fit flex items-center gap-4 hover:scale-105 transition-transform shadow-xl"
                >
                    <img
                        src={DownloadIcon.src}
                        alt=""
                        class="w-6 h-6 brightness-0 invert"
                    />
                    Télécharger le programme en PDF
                </a>
            </div>
        </section>
    </main>

    <section class="px-6 py-12">
        <div class="max-w-7xl mx-auto border-t border-black/10 pt-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">
                {artistes.map((artiste) => <CardProgramme artiste={artiste} />)}
            </div>

            {artistes.length === 0 && (
                <p class="text-center font-playfair text-noir/50 text-2xl py-20">
                    Aucun artiste ne correspond à ces critères.
                </p>
            )}
        </div>
    </section>
</Layout>
