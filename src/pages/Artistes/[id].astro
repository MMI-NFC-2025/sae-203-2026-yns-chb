---
import { ArtisteId } from "../../../backend/backend.mjs";
import Layout from "../../layouts/Layout.astro";
import PbImage from "../../components/PbImage.astro";


import calendarIcon from "../../assets/icons/Calendar.svg?raw";
import locationIcon from "../../assets/icons/Location.svg?raw";
import timeIcon from "../../assets/icons/Time.svg?raw";


const { id } = Astro.params;
const artiste = await ArtisteId(id);


if (!artiste) {
    return Astro.redirect("/Artistes");
}


const rawImage = artiste.Image ?? artiste.photo;
const imageArtiste = Array.isArray(rawImage)
    ? rawImage[0]
    : rawImage || (Array.isArray(artiste.galerie) ? artiste.galerie[0] : "");


const galerieImages = Array.isArray(artiste.galerie)
    ? artiste.galerie
    : Array.isArray(rawImage)
      ? rawImage
      : rawImage
        ? [rawImage]
        : [];

const pageTitle = `${artiste.nom} - Flying Tap Fest`;
---

<Layout title={pageTitle}>
    <main class="bg-beige min-h-screen">
        <header
            class="bg-beige px-6 py-10 lg:px-12 lg:py-16 border-b border-black/5"
        >
            <div class="max-w-7xl mx-auto">
                <a
                    href="/Artistes"
                    class="flex items-center gap-2 text-rouge font-playfair text-2xl mb-10 hover:underline"
                >
                    <span class="text-2xl">←</span> Retour à la liste des artistes
                </a>
                <h1
                    class="font-abril text-moutarde text-7xl lg:text-9xl leading-[0.8] mb-2"
                >
                    {artiste.nom}
                </h1>
                <p class="font-abril text-rouge text-4xl lg:text-6xl ">
                    {artiste.genre_musicale}
                </p>
            </div>
        </header>

        <section class="bg-noir w-full flex justify-center">
            <div class="w-full max-w-[1400px]">
                <PbImage
                    record={artiste}
                    recordImage={imageArtiste}
                    className="w-full h-auto block"
                />
            </div>
        </section>

        <div class="max-w-4xl mx-auto px-6 py-16 space-y-20">
            <div
                class="bg-[#1a1a1a] rounded-[60px] p-8 lg:p-12 shadow-xl flex flex-col md:flex-row justify-between items-center gap-8 border border-white/5"
            >
                <div
                    class="flex flex-col items-center md:items-start gap-2 text-center md:text-left"
                >
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 flex-shrink-0 [&>svg]:w-full [&>svg]:h-full" style="color: var(--color-moutarde)" set:html={locationIcon} />
                        <h2
                            class="font-abril text-moutarde text-xl uppercase tracking-wider"
                        >
                            Scène
                        </h2>
                    </div>
                    <p class="font-playfair text-beige text-xl lg:text-2xl">
                        {artiste.scene}
                    </p>
                </div>
                <div class="hidden md:block w-px h-16 bg-white/10"></div>
                <div
                    class="flex flex-col items-center md:items-start gap-2 text-center md:text-left"
                >
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 flex-shrink-0 [&>svg]:w-full [&>svg]:h-full" style="color: var(--color-moutarde)" set:html={calendarIcon} />
                        <h2
                            class="font-abril text-moutarde text-xl uppercase tracking-wider"
                        >
                            Date
                        </h2>
                    </div>
                    <p class="font-playfair text-beige text-xl lg:text-2xl">
                        {artiste.date}
                    </p>
                </div>
                <div class="hidden md:block w-px h-16 bg-white/10"></div>
                <div
                    class="flex flex-col items-center md:items-start gap-2 text-center md:text-left"
                >
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 flex-shrink-0 [&>svg]:w-full [&>svg]:h-full" style="color: var(--color-moutarde)" set:html={timeIcon} />
                        <h2
                            class="font-abril text-moutarde text-xl uppercase tracking-wider"
                        >
                            Horaire
                        </h2>
                    </div>
                    <p class="font-playfair text-beige text-xl lg:text-2xl">
                        {artiste.horraire ?? artiste.horaire}
                    </p>
                </div>
            </div>



        </div>
        <section class="max-w-[1850px] mx-auto px-4 lg:px-10 pt-16 pb-10 border-t border-black/5">
            <h2 class="font-abril text-rouge text-6xl lg:text-8xl italic uppercase leading-none mb-12">
                À propos
            </h2>
            
            <div class="border-2 border-moutarde p-6 lg:p-8 bg-beige/30 w-full">
                <p class="font-playfair text-noir text-xl lg:text-3xl leading-tight">
                    {artiste.description}
                </p>
            </div>
        </section>
        
  
{
            galerieImages.length > 1 && (
                <section class="max-w-[1850px] mx-auto px-4 lg:px-10 pt-10 pb-24 border-t border-black/5">
                    <h2 class="font-abril text-rouge text-6xl lg:text-8xl mb-16  text-center md:text-left">
                        Galerie Photos
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 items-end">
                        {galerieImages.slice(1, 4).map((img: string) => (
                            <div class="flex flex-col gap-4">
                                <div class="bg-noir/5 rounded-[50px] overflow-hidden flex items-end justify-center">
                                    <PbImage
                                        record={artiste}
                                        recordImage={img}
                                        
                                        className="w-full h-auto block rounded-[40px] shadow-xl transition-transform duration-700 hover:scale-105"
                                    />
                                </div>
                            </div>
                        ))}
                    </div>
                </section>
            )
        }
    </main>
</Layout>
