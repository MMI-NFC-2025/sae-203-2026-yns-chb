---
import Layout from "../../layouts/Layout.astro";
import CardArtiste from "../../components/cards/CardArtiste.astro";
import { pb } from "../../../backend/backend.mjs";


const artistes = await pb.collection("artistes").getFullList({
    sort: "nom",
});
