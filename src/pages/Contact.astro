---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact - Flying Tap Fest">
    <main class="bg-[var(--color-beige)] min-h-screen pb-32">
        <header
            class="max-w-[1850px] mx-auto px-4 lg:px-10 py-16 lg:py-24 text-center lg:text-left"
        >
            <h1
                class="font-abril text-[var(--color-moutarde)] text-7xl lg:text-[120px] leading-none mb-4"
            >
                Contact
            </h1>
            <p
                class="font-abril text-[var(--color-rouge)] text-4xl lg:text-6xl"
            >
                Envoyez-nous un message
            </p>
        </header>

        <section class="max-w-[1850px] mx-auto px-4 lg:px-10">
            <div class="max-w-2xl mx-auto">
                <form
                    class="bg-[var(--color-taupe)]/60 rounded-[40px] p-8 lg:p-12 border-[3px] border-[var(--color-moutarde)] shadow-xl space-y-8"
                >
                    <div class="flex flex-col gap-3">
                        <label
                            for="name"
                            class="font-playfair text-[var(--color-noir)] text-2xl lg:text-3xl"
                        >
                            Nom complet
                        </label>
                        <input
                            type="text"
                            id="name"
                            placeholder="Votre nom"
                            class="bg-[var(--color-beige)] border-[3px] border-[var(--color-rouge)] rounded-2xl p-5 text-xl font-playfair focus:outline-none focus:border-[var(--color-moutarde)] transition-all text-[var(--color-moutarde)] placeholder:text-[var(--color-moutarde)]/60"
                        />
                    </div>

                    <div class="flex flex-col gap-3">
                        <label
                            for="email"
                            class="font-playfair text-[var(--color-noir)] text-2xl lg:text-3xl"
                        >
                            Adresse email
                        </label>
                        <input
                            type="email"
                            id="email"
                            placeholder="votre@email.com"
                            class="bg-[var(--color-beige)] border-[3px] border-[var(--color-rouge)] rounded-2xl p-5 text-xl font-playfair focus:outline-none focus:border-[var(--color-moutarde)] transition-all text-[var(--color-moutarde)] placeholder:text-[var(--color-moutarde)]/60"
                        />
                    </div>

                    <div class="flex flex-col gap-3">
                        <label
                            for="subject"
                            class="font-playfair text-[var(--color-noir)] text-2xl lg:text-3xl"
                        >
                            Sujet
                        </label>
                        <input
                            type="text"
                            id="subject"
                            placeholder="Votre sujet"
                            class="bg-[var(--color-beige)] border-[3px] border-[var(--color-rouge)] rounded-2xl p-5 text-xl font-playfair focus:outline-none focus:border-[var(--color-moutarde)] transition-all text-[var(--color-moutarde)] placeholder:text-[var(--color-moutarde)]/60"
                        />
                    </div>

                    <div class="flex flex-col gap-3">
                        <label
                            for="message"
                            class="font-playfair text-[var(--color-noir)] text-2xl lg:text-3xl"
                        >
                            Votre message
                        </label>
                        <textarea
                            id="message"
                            rows="8"
                            placeholder="Écrivez votre message ici..."
                            class="bg-[var(--color-beige)] border-[3px] border-[var(--color-rouge)] rounded-2xl p-5 text-xl font-playfair focus:outline-none focus:border-[var(--color-moutarde)] transition-all text-[var(--color-moutarde)] placeholder:text-[var(--color-moutarde)]/60 resize-none"
                        ></textarea>
                    </div>
                </form>

                <div class="flex justify-center mt-12">
                    <button
                        class="bg-[var(--color-rouge)] text-[var(--color-beige)] px-12 py-5 rounded-full font-playfair text-2xl flex items-center gap-4 hover:brightness-110 transition-all shadow-2xl group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                        >
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"
                            ></polygon>
                        </svg>
                        Envoyer le message
                    </button>
                </div>
            </div>
        </section>

        <section class="max-w-[1850px] mx-auto px-4 lg:px-10 mt-32 pb-32">
            <h2
                class="font-abril text-[var(--color-rouge)] text-6xl lg:text-8xl mb-16"
            >
                Coordonnées
            </h2>

            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12"
            >
                {
                    ["Email", "Téléphone", "Adresse"].map((titre) => (
                        <div class="bg-[var(--color-taupe)]/60 rounded-[60px] p-10 lg:p-14 shadow-xl border-[3px] border-[var(--color-moutarde)] flex flex-col min-h-[420px]">
                            <div
                                class={`flex items-center gap-6 shrink-0 ${titre === "Téléphone" ? "justify-center" : ""}`}
                            >
                                <div class="text-[var(--color-moutarde)]">
                                    {titre === "Email" && (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="45"
                                            height="45"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <rect
                                                width="20"
                                                height="16"
                                                x="2"
                                                y="4"
                                                rx="2"
                                            />
                                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                                        </svg>
                                    )}
                                    {titre === "Téléphone" && (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="45"
                                            height="45"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                        </svg>
                                    )}
                                    {titre === "Adresse" && (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="45"
                                            height="45"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                    )}
                                </div>
                                <h3 class="font-abril text-[var(--color-moutarde)] text-4xl lg:text-5xl">
                                    {titre}
                                </h3>
                            </div>
                            <div
                                class={`font-playfair text-[var(--color-noir)] text-2xl lg:text-3xl space-y-3 mt-10 leading-tight ${titre === "Téléphone" ? "text-center" : "text-left"}`}
                            >
                                {titre === "Email" && (
                                    <>
                                        <p class="break-all">
                                            contact@flyingtapfest.fr
                                        </p>
                                        <p class="break-all">
                                            presse@flyingtapfest.fr
                                        </p>
                                    </>
                                )}
                                {titre === "Téléphone" && (
                                    <>
                                        <p>+33 1 23 45 67 89</p>
                                        <p>Lun-Ven: 9h-18h</p>
                                    </>
                                )}
                                {titre === "Adresse" && (
                                    <>
                                        <p>Flying Tap Fest</p>
                                        <p>123 Avenue des Claquettes</p>
                                        <p>25150 Pont-de-Roide, France</p>
                                    </>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>
    </main>
</Layout>
