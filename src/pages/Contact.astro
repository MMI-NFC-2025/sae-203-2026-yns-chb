---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact - Flying Tap Fest">
    <main class="bg-beige min-h-screen pb-32">
        <header
            class="max-w-462.5 mx-auto px-6 lg:px-10 py-12 lg:py-24 text-left"
        >
            <h1
                class="font-abril text-moutarde text-7xl lg:text-[120px] leading-none mb-2 lg:mb-4"
            >
                Contact
            </h1>
            <p
                class="font-abril text-rouge text-3xl lg:text-6xl"
            >
                Envoyez-nous un message
            </p>
        </header>

        <section class="max-w-462.5 mx-auto px-6 lg:px-10">
            <div class="max-w-2xl mx-auto">
                <form
                    class="bg-[#D9D4C7]/50 rounded-3xl lg:rounded-[40px] p-6 lg:p-12 border lg:border-[3px] border-moutarde shadow-sm lg:shadow-xl space-y-6 lg:space-y-8"
                >
                    <div class="flex flex-col gap-2 lg:gap-3">
                        <label
                            for="name"
                            class="font-playfair text-noir text-lg lg:text-3xl"
                        >
                            Nom complet
                        </label>
                        <input
                            type="text"
                            id="name"
                            placeholder="Votre nom"
                            class="bg-beige border lg:border-[3px] border-rouge rounded-xl lg:rounded-2xl p-3 lg:p-5 text-base lg:text-xl font-playfair focus:outline-none focus:border-moutarde transition-all text-moutarde placeholder:text-moutarde/60"
                        />
                    </div>

                    <div class="flex flex-col gap-2 lg:gap-3">
                        <label
                            for="email"
                            class="font-playfair text-noir text-lg lg:text-3xl"
                        >
                            Adresse email
                        </label>
                        <input
                            type="email"
                            id="email"
                            placeholder="votre@email.com"
                            class="bg-beige border lg:border-[3px] border-rouge rounded-xl lg:rounded-2xl p-3 lg:p-5 text-base lg:text-xl font-playfair focus:outline-none focus:border-moutarde transition-all text-moutarde placeholder:text-moutarde/60"
                        />
                    </div>

                    <div class="flex flex-col gap-2 lg:gap-3">
                        <label
                            for="subject"
                            class="font-playfair text-noir text-lg lg:text-3xl"
                        >
                            Sujet
                        </label>
                        <input
                            type="text"
                            id="subject"
                            placeholder="Votre sujet"
                            class="bg-beige border lg:border-[3px] border-rouge rounded-xl lg:rounded-2xl p-3 lg:p-5 text-base lg:text-xl font-playfair focus:outline-none focus:border-moutarde transition-all text-moutarde placeholder:text-moutarde/60"
                        />
                    </div>

                    <div class="flex flex-col gap-2 lg:gap-3">
                        <label
                            for="message"
                            class="font-playfair text-noir text-lg lg:text-3xl"
                        >
                            Votre message
                        </label>
                        <textarea
                            id="message"
                            rows="6"
                            placeholder="Ã‰crivez votre message ici..."
                            class="bg-beige border lg:border-[3px] border-rouge rounded-xl lg:rounded-2xl p-3 lg:p-5 text-base lg:text-xl font-playfair focus:outline-none focus:border-moutarde transition-all text-moutarde placeholder:text-moutarde/60 resize-none lg:rows-8"
                        ></textarea>
                    </div>
                </form>

                <div class="flex justify-center mt-8 lg:mt-12">
                    <button
                        class="bg-rouge text-beige px-8 py-4 lg:px-12 lg:py-5 rounded-full font-playfair text-lg lg:text-2xl flex items-center gap-3 lg:gap-4 hover:brightness-110 transition-all shadow-xl group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 lg:w-7 lg:h-7 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"
                            ></polygon>
                        </svg>
                        Envoyer le message
                    </button>
                </div>
            </div>
        </section>

        <section
            class="max-w-462.5 mx-auto px-6 lg:px-10 mt-20 lg:mt-32 "
        >
            <h2
                class="font-abril text-rouge text-5xl lg:text-8xl mb-8 lg:mb-16 text-left lg:text-center"
            >
                CoordonnÃ©es
            </h2>

            <div
                class="lg:bg-[#D9D4C7]/50 lg:rounded-[60px] lg:p-16 lg:shadow-xl lg:border-[3px] lg:border-moutarde lg:max-w-7xl lg:mx-auto"
            >
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
                    {
                        ["Email", "TÃ©lÃ©phone", "Adresse"].map((titre) => (
                            <div class="bg-[#D9D4C7]/50 rounded-[30px] p-8 shadow-sm border border-moutarde lg:bg-transparent lg:rounded-none lg:p-0 lg:shadow-none lg:border-none flex flex-col items-start lg:items-center text-left lg:text-center">
                                <div class="flex items-center lg:flex-col gap-3 lg:gap-4 shrink-0 mb-4 lg:mb-6">
                                    <div class="text-moutarde w-6 h-6 lg:w-12 lg:h-12 flex items-center justify-center">
                                        {titre === "Email" && (
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="w-full h-full"
                                            >
                                                <rect
                                                    width="20"
                                                    height="16"
                                                    x="2"
                                                    y="4"
                                                    rx="2"
                                                />
                                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                                            </svg>
                                        )}
                                        {titre === "TÃ©lÃ©phone" && (
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="w-full h-full"
                                            >
                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                            </svg>
                                        )}
                                        {titre === "Adresse" && (
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="w-full h-full"
                                            >
                                                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                                                <circle cx="12" cy="10" r="3" />
                                            </svg>
                                        )}
                                    </div>
                                    <h3 class="font-abril text-moutarde text-2xl lg:text-4xl">
                                        {titre}
                                    </h3>
                                </div>

                                <div class="font-playfair text-noir text-lg lg:text-2xl space-y-1 lg:space-y-2 leading-relaxed">
                                    {titre === "Email" && (
                                        <>
                                            <p class="break-all">
                                                contact@flyingtapfest.fr
                                            </p>
                                            <p class="break-all">
                                                presse@flyingtapfest.fr
                                            </p>
                                        </>
                                    )}
                                    {titre === "TÃ©lÃ©phone" && (
                                        <>
                                            <p>+33 1 23 45 67 89</p>
                                            <p>Lun-Ven: 9h-18h</p>
                                        </>
                                    )}
                                    {titre === "Adresse" && (
                                        <>
                                            <p>Flying Tap Fest</p>
                                            <p>123 Avenue des Claquettes</p>
                                            <p>25150 Pont-de-Roide, France</p>
                                        </>
                                    )}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>

