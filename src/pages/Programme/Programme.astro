---
import Layout from "../../layouts/Layout.astro";
import CardProgramme from "../../components/cards/CardProgramme.astro";
import { getFilteredArtists, getToutesLesScenes, getArtistsByDate } from '../../../backend/backend.mjs';
import DownloadIcon from '../../assets/icons/Telechargement.svg'

const genre = Astro.url.searchParams.get('genre') || "";
const scene = Astro.url.searchParams.get('scene') || "";
const ordre = Astro.url.searchParams.get('ordre') || "asc";

// On appelle ta fonction backend directement ici

const allArtistes = await getArtistsByDate();
const artistes = await getFilteredArtists(genre, scene, ordre);
const toutesLesScenes = await getToutesLesScenes();
// const listeGenres = [
//     "Jeune Talent", "Comédie Tap", "Soul Tap", 
//     "Tap Jazz", "Hip-Hop Tap", "Irish Tap", "Flamenco Tap"
// ];
console.log(artistes);

const listeGenres = [...new Set(allArtistes.map(a => a.genre_musicale))];
---

<Layout title="Programme - Flying Tap Fest">
    <main class="bg-beige min-h-screen pb-24">
        
<section class="pt-20 lg:pt-32 pb-12 px-6">
            <div class="max-w-7xl mx-auto">
                <h1 class="font-abril text-moutarde text-7xl lg:text-9xl uppercase leading-none text-left">
                    Programme
                </h1>
            </div>
        </section>
<section class="px-6 mb-20">
    <div class="max-w-7xl mx-auto flex flex-col items-center gap-10">
        
        <div class="bg-[#1A1A1A] rounded-[40px] p-8 lg:p-12 w-full max-w-5xl shadow-2xl">
            
            <div class="flex items-center gap-3 mb-10 text-moutarde">
                 <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
                 <span class="font-playfair italic text-2xl">Filtres</span>
            </div>

            <form method="GET" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                
                <div class="flex flex-col gap-2">
                    <label class="font-playfair text-beige/50 text-lg ml-4">Genre</label>
                    <select name="genre" onchange="this.form.submit()" class="bg-beige text-moutarde font-playfair text-xl py-4 px-6 rounded-full appearance-none outline-none cursor-pointer w-full">
                        <option value="">Tous les genres</option>
                        {listeGenres.map((g) => <option value={g} selected={genre === g}>{g}</option>)}
                    </select>
                </div>

                <div class="flex flex-col gap-2">
                    <label class="font-playfair text-beige/50 text-lg ml-4">Horaire</label>
                    <select name="ordre" onchange="this.form.submit()" class="bg-beige text-moutarde font-playfair text-xl py-4 px-6 rounded-full appearance-none outline-none cursor-pointer w-full">
                        <option value="asc" selected={ordre === "asc"}>Le plus tôt</option>
                        <option value="desc" selected={ordre === "desc"}>Le plus tard</option>
                    </select>
                </div>

                <div class="flex flex-col gap-2">
                    <label class="font-playfair text-beige/50 text-lg ml-4">Scène</label>
                    <select name="scene" onchange="this.form.submit()" class="bg-beige text-moutarde font-playfair text-xl py-4 px-6 rounded-full appearance-none outline-none cursor-pointer w-full">
                        <option value="">Toutes les scènes</option>
                        {toutesLesScenes.map((s) => <option value={s.nom_scene} selected={scene === s.nom_scene}>{s.nom_scene}</option>)}
                    </select>
                </div>

            </form>
        </div>

        <a href="/programme.pdf" class="bg-rouge text-beige font-abril text-xl py-5 px-10 rounded-full w-fit flex items-center gap-4 hover:scale-105 transition-transform shadow-xl">
            Télécharger le programme en PDF
        </a>
    </div>
</main>
</section>

<section class="px-6 py-12">
    <div class="max-w-7xl mx-auto border-t border-black/10 pt-12">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
            {artistes.map((a) => (
                <CardProgramme 
                    nom={a.nom}
                    genre_musicale={a.genre_musicale}
                    scene={a.scene}
                    horaire={a.horraire}
                    record={a}
                    recordImage={Array.isArray(a.Image) ? a.Image[0] : a.Image}
                />
            ))}
        </div>

        {/* ... message si aucun artiste ... */}
    </div>
</section>
</Layout>