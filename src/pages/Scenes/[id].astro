---
import Layout from "../../layouts/Layout.astro";
import { getArtistsBySceneId, SceneId } from "../../../backend/backend.mjs";
import CardProgramme from "../../components/cards/CardProgramme.astro";
import PbImage from "../../components/PbImage.astro";

const { id } = Astro.params;
const scene = await SceneId(id);
const artistes = await getArtistsBySceneId(id);

if (!scene) {
    return Astro.redirect("/Scenes");
}

const pageTitle = `Programmation ${scene.nom_scene} - Flying Tap Fest`;
---

<Layout title={pageTitle}>
    <main class="bg-beige min-h-screen">
        <header class="w-full bg-beige">
            <div class="max-w-462.5 mx-auto px-6 lg:px-10 py-10 lg:py-12">
                <a
                    href="/Scenes"
                    class="flex items-center gap-2 text-rouge font-playfair text-2xl lg:text-2xl mb-8 hover:underline"
                >
                    <span class="text-xl">←</span> Retour à la liste des scènes
                </a>

                <h1
                    class="font-abril text-moutarde text-6xl md:text-7xl lg:text-[150px] leading-tight lg:leading-none mb-2"
                >
                    {scene.nom_scene}
                </h1>
                <p
                    class="font-abril text-rouge text-3xl lg:text-6xl mb-8 lg:mb-12"
                >
                    {scene.localisation}
                </p>
            </div>

            <div
                class="w-full relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw]"
            >
                <PbImage
                    record={scene}
                    recordImage={scene.photo}
                    className="w-full h-auto min-h-[40vh] lg:h-[80vh] object-cover shadow-2xl"
                />
            </div>
        </header>

        <section class="max-w-462.5 mx-auto px-6 lg:px-10 py-12 lg:py-16">
            <h2
                class="font-abril text-rouge text-4xl lg:text-8xl mb-8 lg:mb-12"
            >
                Artistes Présents
            </h2>

            {
                [...new Set(artistes.map((a) => a.date?.trim()))].map(
                    (dateUnique) => (
                        <div class="mb-16 lg:mb-20 w-full">
                            <h3 class="font-abril text-moutarde text-2xl lg:text-4xl mb-8">
                                {dateUnique}
                            </h3>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-20 w-full">
                                {artistes
                                    .filter(
                                        (a) => a.date?.trim() === dateUnique,
                                    )
                                    .map((artiste) => (
                                        <a
                                            href={`/Artistes/${artiste.id}`}
                                            class="block transition-transform duration-300 hover:scale-[1.02]"
                                        >
                                            <CardProgramme artiste={artiste} />
                                        </a>
                                    ))}
                            </div>
                        </div>
                    ),
                )
            }
        </section>
    </main>
</Layout>
