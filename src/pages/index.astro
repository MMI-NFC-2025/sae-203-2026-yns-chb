---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CardFestival from "../components/cards/CardFestival.astro";

import dronesImg from "../assets/img/drone.jpg";
import programmeImg from "../assets/img/programme.jpg";
import artistesImg from "../assets/img/artistes.jpg";
import infosImg from "../assets/img/infos_pratiques.avif";

import logoDecathlon from '../assets/img/decathlon.jpg';
import logoPMA from '../assets/img/pma.jpg';
import logoMolo from '../assets/img/moloco.jpg';
import logoCM from '../assets/img/creditmutuel.jpg';

const logos = [
    { src: logoDecathlon, alt: 'Decathlon' },
    { src: logoPMA, alt: 'Pays de Montbéliard Agglomération' },
    { src: logoMolo, alt: 'Le Moloco' },
    { src: logoCM, alt: 'Crédit Mutuel' },
];

// On multiplie la liste pour que le défilement soit fluide et infini
const duplicatedLogos = [...logos, ...logos, ...logos, ...logos];
---

<Layout
	title="Accueil"
	description="Bienvenue au Flying Tap Fest, un festival de claquettes entre ciel et terre !"
>
	<Hero />
	<section class="bg-beige py-24 px-6 relative z-10">
		<div class="max-w-7xl mx-auto">
			<div class="grille">
				<div
					class="col-span-12 lg:col-span-3 flex flex-col items-center text-center gap-2"
				>
					<span
						class="font-abril text-rouge text-7xl lg:text-8xl leading-none"
					>
						100+
					</span>
					<span
						class="font-playfair text-black text-xl italic lg:not-italic lg:font-bold"
					>
						Drones pour le show
					</span>
				</div>

				<div
					class="col-span-12 lg:col-span-3 flex flex-col items-center text-center gap-2"
				>
					<span
						class="font-abril text-rouge text-7xl lg:text-8xl leading-none"
					>
						2
					</span>
					<span
						class="font-playfair text-black text-xl italic lg:not-italic lg:font-bold"
					>
						Jours de festival
					</span>
				</div>

				<div
					class="col-span-12 lg:col-span-3 flex flex-col items-center text-center gap-2"
				>
					<span
						class="font-abril text-rouge text-7xl lg:text-8xl leading-none"
					>
						1k
					</span>
					<span
						class="font-playfair text-black text-xl italic lg:not-italic lg:font-bold"
					>
						Spectateurs
					</span>
				</div>

				<div
					class="col-span-12 lg:col-span-3 flex flex-col items-center text-center gap-2"
				>
					<span
						class="font-abril text-rouge text-7xl lg:text-8xl leading-none"
					>
						8+
					</span>
					<span
						class="font-playfair text-black text-xl italic lg:not-italic lg:font-bold"
					>
						Artistes sur scène
					</span>
				</div>
			</div>
		</div>
	</section>

		<section class="bg-taupe py-24 px-6">
    <div class="max-w-7xl mx-auto">
        
        <div class="text-center mb-20 flex flex-col gap-6">
            <h2 class="font-abril text-4xl md:text-6xl lg:text-7xl text-black uppercase tracking-tight">
                Explorez le Festival
            </h2>
            <p class="font-playfair text-xl lg:text-2xl text-black italic opacity-90">
                Découvrez tout ce que le Flying Tap Fest a à offrir
            </p>
        </div>

        <div class="grille gap-y-12">
            </div>
    </div>


				<div class="grille gap-y-12">
					<div class="col-span-12 lg:col-span-6">
						<CardFestival
							title="Drones"
							description="Le spectacle de drones sera un moment magique où des centaines de lumières danseront dans le ciel..."
							imgSrc={dronesImg}
							href="/drones"
						/>
					</div>

					<div class="col-span-12 lg:col-span-6">
						<CardFestival
							title="Programme"
							description="Découvrez notre programmation complète avec plus de 8 artistes sur 2 jours..."
							imgSrc={programmeImg}
							href="/programme"
						/>
					</div>

					<div class="col-span-12 lg:col-span-6">
						<CardFestival
							title="Artistes"
							description="Des légendes des claquettes aux jeunes prodiges, rencontrez tous nos artistes exceptionnels..."
							imgSrc={artistesImg}
							href="/artistes"
						/>
					</div>

					<div class="col-span-12 lg:col-span-6">
						<CardFestival
							title="Infos Pratiques"
							description="Tarifs, accès, hébergement... Toutes les informations pour préparer votre venue au festival..."
							imgSrc={infosImg}
							href="/infos"
						/>
					</div>
				</div>
			</div>
		</section>


		<section class="bg-beige py-12 border-y border-taupe/30 overflow-hidden">
    
    <div class="max-w-7xl mx-auto px-6 mb-8">
        <div class="grille">
            <div class="col-span-12">
                <h2 class="font-abril text-2xl uppercase  text-center">Nos Partenaires</h2>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-16 animate-scroll whitespace-nowrap">
        {duplicatedLogos.map((logo) => (
            <div class="flex-shrink-0">
                <Image 
                    src={logo.src} 
                    alt={logo.alt} 
                    class="h-12 lg:h-16 w-auto object-contain "
                />
            </div>
        ))}
    </div>
</section>

<section class="w-full">
    <div class="w-full bg-gradient-to-b from-rouge to-moutarde py-24 px-6 text-center shadow-2xl">
        <div class="max-w-4xl mx-auto flex flex-col items-center">
            <h2 class="font-abril text-white text-5xl lg:text-8xl leading-tight mb-8">
                Prêt à vivre <br/> l'expérience ?
            </h2>
            <p class="font-playfair text-white text-xl lg:text-3xl ic mb-14 opacity-90">
                Ne manquez pas l'événement <br class="md:hidden"/> incontournable de l'été 2026
            </p>
            <a href="/Contact" class="bg-beige text-rouge font-abril text-xl lg:text-2xl px-16 py-6 rounded-full hover:scale-105 transition-transform duration-300 shadow-xl">
                Reserver maintenant
            </a>
        </div>
    </div>
</section>
</Layout>
