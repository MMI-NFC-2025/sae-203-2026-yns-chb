---
import Layout from "../layouts/Layout.astro";
import CardEquipe from "../components/cards/CardEquipe.astro";

import infosImage from "../assets/img/infos_pratiques.avif";
import Marie from "../assets/img/Marie.jpg";
import Thomas from "../assets/img/Thomas.jpg";
import Sophie from "../assets/img/Sophie.jpg";
import Lucas from "../assets/img/Lucas.jpg";

const equipe = [
    {
        title: "Marie Dubois",
        subtitle: "Directrice Artistique",
        img: Marie,
        desc: "Danseuse et chorégraphe reconnue, Marie dirige le festival depuis sa création.",
    },
    {
        title: "Thomas Martin",
        subtitle: "Directeur Technique",
        img: Thomas,
        desc: "Expert en son et lumière, Thomas assure la qualité technique de tous les spectacles.",
    },
    {
        title: "Sophie Laurent",
        subtitle: "Coordinatrice",
        img: Sophie,
        desc: "Sophie gère la logistique et coordonne les équipes bénévoles avec passion.",
    },
    {
        title: "Lucas Bernard",
        subtitle: "Chargé de Communication",
        img: Lucas,
        desc: "Lucas pilote toute la communication et les relations presse du festival.",
    },
];
---

<Layout
    title="À propos"
    description="Découvrez l'histoire et la vision du Flying Tap Fest, un festival de claquettes innovant à Montbéliard."
>
    <section class="bg-beige py-12 lg:py-32 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col gap-10 lg:gap-16">
                <div class="flex flex-col gap-4">
                    <h1
                        class="font-abril text-moutarde text-6xl lg:text-9xl leading-none  tracking-tighter"
                    >
                        Le Festival
                    </h1>
                    <h2
                        class="font-abril text-rouge text-4xl lg:text-6xl"
                    >
                        Notre Histoire
                    </h2>
                </div>

                <div
                    class="flex flex-col gap-8 text-noir font-playfair text-xl lg:text-3xl leading-relaxed"
                >
                    <p>
                        Le Flying Tap Fest est un festival né d'une ambition
                        claire :
                        <span class="font-bold"
                            >réunir l'énergie rythmée des claquettes et la
                            poésie lumineuse des drones</span
                        >, afin de proposer une expérience artistique nouvelle.
                        Imaginé dans le cadre d'une stratégie de communication
                        axée sur la modernité et l'ouverture culturelle, le
                        festival voit le jour avec la volonté de dépoussiérer la
                        discipline des claquettes tout en respectant son
                        héritage.
                    </p>

                    <p>
                        Le festival se déroule au <span class="font-bold"
                            >Parc du Près-la-Rose à Montbéliard</span
                        >, les <span class="font-bold">6 et 7 juin 2026</span>,
                        au début de la période estivale, pour accueillir aussi
                        bien les familles, les passionnés de danse, que les
                        curieux en quête d'expériences innovantes.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-beige px-6 pb-12">
        <div class="max-w-7xl mx-auto">
            <div class="overflow-hidden rounded-2xl shadow-lg">
                <img
                    src={infosImage.src}
                    alt="Ambiance festive du festival"
                    class="w-full h-87.5 lg:h-150 object-cover"
                />
            </div>
        </div>
    </section>

    <section class="bg-beige px-6 pb-16 lg:pb-32">
        <div class="max-w-5xl mx-auto">
            <div
                class="bg-noir rounded-[40px] lg:rounded-[60px] p-8 lg:p-20 shadow-2xl"
            >
                <div class="flex flex-col gap-8 lg:gap-10">
                    <h2
                        class="font-abril text-taupe text-3xl lg:text-5xl leading-tight"
                    >
                        Pensé pour mélanger tradition et modernité, il associe :
                    </h2>

                    <ul
                        class="flex flex-col gap-4 font-playfair text-white text-xl lg:text-2xl opacity-90"
                    >
                        <li class="flex items-start gap-3">
                            <span class="text-moutarde">•</span>
                            spectacles de claquettes,
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-moutarde">•</span>
                            performances lumineuses de drones,
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-moutarde">•</span>
                            ateliers culturels et intergénérationnels,
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-moutarde">•</span>
                            rencontres avec les artistes.
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-beige pb-12 lg:pb-32 overflow-hidden">
        <div class="max-w-7xl mx-auto px-6 mb-12">
            <h2
                class="font-abril text-rouge text-5xl lg:text-7xl"
            >
                Notre équipe
            </h2>
        </div>

        <div class="flex gap-8 animate-scroll-equipe hover:pause">
            {
                [...Array(3)].map(() => (
                    <>
                        <CardEquipe
                            title="Marie Dubois"
                            subtitle="Directrice Artistique"
                            description="Danseuse et chorégraphe reconnue, Marie dirige le festival depuis sa création."
                            imgSrc={Marie}
                        />
                        <CardEquipe
                            title="Thomas Martin"
                            subtitle="Directeur Technique"
                            description="Expert en son et lumière, Thomas assure la qualité technique de tous les spectacles."
                            imgSrc={Thomas}
                        />
                        <CardEquipe
                            title="Sophie Laurent"
                            subtitle="Coordinatrice"
                            description="Sophie gère la logistique et coordonne les équipes bénévoles."
                            imgSrc={Sophie}
                        />
                        <CardEquipe
                            title="Lucas Bernard"
                            subtitle="Chargé de Communication"
                            description="Lucas pilote toute la communication et les relations presse."
                            imgSrc={Lucas}
                        />
                    </>
                ))
            }
        </div>
    </section>

    <section
        class="bg-beige pt-8 pb-10 lg:pt-24 lg:pb-24 px-6 border-t border-black/5"
    >
        <div class="max-w-7xl mx-auto">
            <div class="mb-10 lg:mb-16">
                <h2
                    class="font-abril text-rouge text-5xl lg:text-8xl leading-none"
                >
                    Nos Valeurs
                </h2>
            </div>

            <div class="flex flex-col gap-12 lg:gap-24">
                <div class="flex flex-col gap-4">
                    <h3
                        class="font-abril text-moutarde text-3xl lg:text-5xl leading-tight"
                    >
                        Éco-Responsabilité Exemplaire
                    </h3>
                    <p
                        class="font-playfair text-noir text-xl lg:text-3xl leading-relaxed opacity-90"
                    >
                        Le Flying Tap Fest place l'environnement au cœur de son
                        organisation. Communication numérique, impressions sur
                        papier recyclé et gestion rigoureuse des déchets
                        garantissent un événement à l'empreinte aussi légère que
                        nos pas de claquettes.
                    </p>
                </div>

                <div class="flex flex-col gap-4">
                    <h3
                        class="font-abril text-moutarde text-3xl lg:text-5xl leading-tight"
                    >
                        Innovation & Créativité
                    </h3>
                    <p
                        class="font-playfair text-noir text-xl lg:text-3xl leading-relaxed opacity-90"
                    >
                        Nous réinventons l'expérience du spectacle vivant en
                        fusionnant claquettes et drones lumineux. Cette approche
                        moderne offre au public un univers visuel inédit, mêlant
                        technologie, mouvement et poésie.
                    </p>
                </div>

                <div class="flex flex-col gap-4">
                    <h3
                        class="font-abril text-moutarde text-3xl lg:text-5xl leading-tight"
                    >
                        Culture & Transmission
                    </h3>
                    <p
                        class="font-playfair text-noir text-xl lg:text-3xl leading-relaxed opacity-90"
                    >
                        Le festival s'engage à valoriser les claquettes comme
                        discipline artistique accessible à tous. Ateliers,
                        rencontres et cours permettent aux visiteurs de
                        découvrir, apprendre et partager, quel que soit leur âge
                        ou leur niveau.
                    </p>
                </div>

                <div class="flex flex-col gap-4">
                    <h3
                        class="font-abril text-moutarde text-3xl lg:text-5xl leading-tight"
                    >
                        Ouverture au Public
                    </h3>
                    <p
                        class="font-playfair text-noir text-xl lg:text-3xl leading-relaxed opacity-90"
                    >
                        Pensé pour les jeunes, les familles, les passionnés
                        comme les curieux, le Flying Tap Fest propose un
                        programme intergénérationnel et inclusif, réunissant
                        tradition, modernité et convivialité.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-beige pt-2 pb-20 px-6">
        <div class="max-w-4xl mx-auto">
            <div
                class="w-full bg-linear-to-b from-rouge to-moutarde rounded-[20px] p-10 lg:p-24 text-center flex flex-col gap-8 shadow-2xl"
            >
                <h2
                    class="font-abril text-beige text-5xl lg:text-9xl leading-none text-center"
                >
                    Édition 2026
                </h2>
                <div class="flex flex-col gap-4 text-beige">
                    <p
                        class="font-playfair text-xl lg:text-4xl text-center"
                    >
                        "Un festival entre ciel et terre"
                    </p>
                    <p
                        class="font-playfair text-xl lg:text-4xl leading-tight text-center"
                    >
                        Une célébration des claquettes<br
                            class="hidden lg:block"
                        /> à travers les cultures
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    @keyframes scrollEquipe {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(calc(-412px * 4));
        }
    }
    .animate-scroll-equipe {
        display: flex;
        width: max-content;
        animation: scrollEquipe 30s linear infinite;
    }
    .hover\:pause:hover {
        animation-play-state: paused;
    }
    @media (max-width: 1024px) {
        @keyframes scrollEquipe {
            0% {
                transform: translateX(0);
            }
            100% {
                transform: translateX(calc(-352px * 4));
            }
        }
    }
</style>


