---
// src/components/CardProgramme.astro
import PbImage from "../PbImage.astro";

interface Props {
    artiste: any;
}

const { artiste } = Astro.props;

// Sécurité pour l'image
const rawImage = artiste.Image ?? artiste.photo;
const imageArtiste = Array.isArray(rawImage) ? rawImage[0] : rawImage;
---

<div
    class="bg-taupe rounded-[50px] overflow-hidden flex flex-col group hover:shadow-xl transition-all duration-500 h-full border border-black/5"
>
    <div class="relative w-full flex items-center justify-center">
        <PbImage
            record={artiste}
            recordImage={imageArtiste}
            className="w-full h-auto block transition-transform duration-700 group-hover:scale-105"
        />
    </div>

    <div class="p-10 lg:p-12 flex flex-col gap-6">
        <div class="flex flex-col gap-2">
            <h3
                class="font-abril text-moutarde text-4xl lg:text-5xl leading-tight "
            >
                {artiste.nom}
            </h3>
            <p class="font-playfair text-rouge text-2xl font-bold ">
                {artiste.genre_musicale}
            </p>
        </div>

        <div
            class="flex flex-col gap-4 font-playfair /80 border-t border-black/10 pt-6"
        >
            <p class="text-2xl lg:text-3xl">
                <span class="text-rouge font-bold ">Horaire :</span>
                {artiste.horraire ?? artiste.horaire}
            </p>
            <p class="text-2xl lg:text-3xl">
                <span class="text-rouge font-bold ">Scène :</span>
                {artiste.scene}
            </p>
        </div>
    </div>
</div>
