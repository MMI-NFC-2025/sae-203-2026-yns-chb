---
import Facebook from "../assets/icons/Bulle_facebook.svg";
import Instagram from "../assets/icons/Bulle_insta.svg";
import TwitterX from "../assets/icons/Bulle_X.svg";
import Youtube from "../assets/icons/Bulle_youtube.svg";
---

<footer class="bg-[var(--color-noir)] text-white py-16 px-6 lg:py-24">
    <div class="max-w-7xl mx-auto">
        <div
            class="flex flex-col lg:flex-row lg:justify-between gap-y-12 lg:gap-x-12 text-left"
        >
            <div class="flex flex-col gap-5 max-w-sm">
                <h2
                    class="font-abril text-[var(--color-moutarde)] text-4xl lg:text-5xl"
                >
                    Flying Tap Fest
                </h2>
                <p class="font-playfair text-lg opacity-80 leading-relaxed">
                    Le festival de claquettes qui fait vibrer Montbéliard chaque
                    été. Une célébration de la danse, du rythme et de la culture
                    tap.
                </p>
            </div>

            <div class="flex flex-col gap-6">
                <h3
                    class="font-abril text-[var(--color-moutarde)] text-2xl uppercase tracking-wider"
                >
                    Liens Rapides
                </h3>
                <nav class="flex flex-col gap-4">
                    <a
                        href="/"
                        class="font-playfair text-lg hover:text-[var(--color-moutarde)] transition-colors w-fit italic lg:not-italic"
                        >Le Festival</a
                    >
                    <a
                        href="/Programme"
                        class="font-playfair text-lg hover:text-[var(--color-moutarde)] transition-colors w-fit italic lg:not-italic"
                        >Programme</a
                    >
                    <a
                        href="/Artistes"
                        class="font-playfair text-lg hover:text-[var(--color-moutarde)] transition-colors w-fit italic lg:not-italic"
                        >Artistes</a
                    >
                    <a
                        href="/Info"
                        class="font-playfair text-lg hover:text-[var(--color-moutarde)] transition-colors w-fit italic lg:not-italic"
                        >Infos Pratiques</a
                    >
                    <a
                        href="/Contact"
                        class="font-playfair text-lg hover:text-[var(--color-moutarde)] transition-colors w-fit italic lg:not-italic"
                        >Contact</a
                    >
                </nav>
            </div>

            <div class="flex flex-col gap-6">
                <h3
                    class="font-abril text-[var(--color-moutarde)] text-2xl uppercase tracking-wider"
                >
                    Suivez-nous
                </h3>
                <div class="flex gap-4">
                    <a
                        href="https://facebook.com"
                        target="_blank"
                        class="hover:scale-110 transition-transform"
                    >
                        <img
                            src={Facebook.src}
                            alt="Facebook"
                            class="w-12 h-12"
                        />
                    </a>
                    <a
                        href="https://youtube.com"
                        target="_blank"
                        class="hover:scale-110 transition-transform"
                    >
                        <img
                            src={Youtube.src}
                            alt="Youtube"
                            class="w-12 h-12"
                        />
                    </a>
                    <a
                        href="https://x.com"
                        target="_blank"
                        class="hover:scale-110 transition-transform"
                    >
                        <img
                            src={TwitterX.src}
                            alt="X (Twitter)"
                            class="w-12 h-12"
                        />
                    </a>
                    <a
                        href="https://instagram.com"
                        target="_blank"
                        class="hover:scale-110 transition-transform"
                    >
                        <img
                            src={Instagram.src}
                            alt="Instagram"
                            class="w-12 h-12"
                        />
                    </a>
                </div>
            </div>
        </div>

        <div
            class="border-t border-white/10 pt-10 mt-16 text-center lg:text-center"
        >
            <p
                class="font-playfair opacity-60 text-base lg:text-lg italic leading-relaxed"
            >
                © 2026 Flying Tap Fest. Tous droits réservés.
            </p>
        </div>
    </div>
</footer>
