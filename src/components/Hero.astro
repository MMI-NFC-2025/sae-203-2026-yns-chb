---
import { Image } from "astro:assets";

import heroImage from "../assets/img/hero.jpg";
import StarsIcon from "../assets/icons/Stars.svg";
import CalendarIcon from "../assets/icons/Calendar.svg";
import LocationIcon from "../assets/icons/Location.svg";
import ArrowDownIcon from "../assets/icons/Arrow_Down.svg";

const {
    edition = "Première Édition : Rythmes du Monde",
    date = "Du 06 au 07 juin 2026",
    lieu = "Près-la-Rose à Montbéliard",
} = Astro.props;
---

<section
    class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-black"
>
    <div class="absolute inset-0 z-0">
        <Image
            src={heroImage}
            alt="Danseur"
            class="w-full h-full object-cover brightness-[0.4]"
        />
    </div>

    <div class="relative z-10 w-full max-w-7xl px-6">
        <div class="grille -translate-y-8">
            <div class="col-span-12 flex flex-col items-center gap-8">
                <div
                    class="border border-white/30 bg-white/10 backdrop-blur-md px-6 py-2 rounded-full flex items-center gap-3"
                >
                    <StarsIcon class="w-5 h-5 text-moutarde" />
                    <span
                        class="font-playfair text-white text-lg lg:text-xl italic"
                        >{edition}</span
                    >
                </div>

                <h1
                    class="font-abril text-white text-[14vw] lg:text-[7.5vw] leading-[0.85] uppercase text-center"
                >
                    Flying Tap <br /> Fest
                </h1>

                <p
                    class="font-playfair text-white text-xl lg:text-3xl italic opacity-90"
                >
                    Un festival entre ciel et terre
                </p>

                <div class="flex flex-col gap-4">
                    <div
                        class="border border-white/20 bg-black/40 backdrop-blur-sm px-10 py-3 rounded-full flex items-center gap-5 min-w-[320px] justify-center"
                    >
                        <CalendarIcon class="w-6 h-6 text-moutarde" />
                        <span
                            class="font-playfair text-white text-xl lg:text-2xl"
                            >{date}</span
                        >
                    </div>
                    <div
                        class="border border-white/20 bg-black/40 backdrop-blur-sm px-10 py-3 rounded-full flex items-center gap-5 min-w-[320px] justify-center"
                    >
                        <LocationIcon class="w-6 h-6 text-moutarde" />
                        <span
                            class="font-playfair text-white text-xl lg:text-2xl"
                            >{lieu}</span
                        >
                    </div>
                </div>

                <a
                    href="/Contact"
                    class="bg-rouge hover:bg-moutarde text-white font-abril text-xl lg:text-2xl px-12 py-5 rounded-full transition-all"
                >
                    Réserver vos billets
                </a>
            </div>
        </div>
    </div>

    <div
        class="absolute bottom-5 left-1/2 -translate-x-1/2 animate-bounce z-20"
    >
        <ArrowDownIcon class="w-8 h-8 text-white" />
    </div>
</section>
